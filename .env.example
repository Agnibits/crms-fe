# ── API ──────────────────────────────────────────────────────────────
# Base URL of the Node.js/Express REST API
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Socket.io server URL for realtime notifications
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# ── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=AgniBits CRM
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Development ──────────────────────────────────────────────────────
# When "true", all API calls are served from an in-browser mock adapter
# with seeded demo data (no backend required). Set to "false" to hit the
# real API at NEXT_PUBLIC_API_URL.
# NOTE: this flag is IGNORED in production builds (NODE_ENV=production) — mock
# mode is hard-disabled there so demo data can never reach real users.
NEXT_PUBLIC_USE_MOCK=true

# ── AI (Sales Copilot & email writer) ────────────────────────────────
# Add ONE provider key. If both are set, AI_PROVIDER decides (default: groq).
# Leave both empty to use built-in demo/mock AI responses.

# Groq — recommended, reliable free tier: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini — free key: https://aistudio.google.com/apikey
# (If you get a 429 "limit: 0", create the key in a NEW project.)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional explicit provider: "groq" or "gemini". Empty = auto-detect.
AI_PROVIDER=
